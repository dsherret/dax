{
  "name": "@david/dax",
  "nodeModulesDir": "none",
  "workspace": [
    "./docs"
  ],
  "test": {
    "permissions": {
      "all": true
    }
  },
  "tasks": {
    "dnt": "deno run -A ./scripts/build_npm.ts",
    "test": "deno test -A"
  },
  "fmt": {
    "proseWrap": "preserve",
    "operatorPosition": "nextLine",
    "lineWidth": 120
  },
  "lint": {
    "rules": {
      "exclude": ["ban-types", "no-explicit-any", "no-this-alias", "no-process-global"],
      "include": [
        "no-console",
        "no-sync-fn-in-async-fn"
      ]
    }
  },
  "exclude": [
    ".gitignore",
    ".github",
    ".vscode",
    "docs/",
    "npm/"
  ],
  "exports": "./mod.ts",
  "imports": {
    "@david/console-static-text": "jsr:@david/console-static-text@^0.3.4",
    "@david/shell": "jsr:@david/shell@^0.5.2",
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@david/path": "jsr:@david/path@^0.3.2",
    "@std/assert": "jsr:@std/assert@1",
    "@std/async": "jsr:@std/async@1",
    "@std/fmt": "jsr:@std/fmt@1",
    "@std/io": "jsr:@std/io@^0.225",
    "@std/path": "jsr:@std/path@1",
    "which": "jsr:@david/which@^0.7.0",
    "which_runtime": "jsr:@david/which-runtime@^0.2.1"
  }
}
